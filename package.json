{
  "name": "nielson-pinheiro-engenheiro-civil",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen:sitemap": "node scripts/gen-sitemap.mjs",
    "gen:og": "node scripts/gen-og-image.mjs",
    "gen:map": "node scripts/gen-map-image.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "prebuild": "node scripts/gen-sitemap.mjs",
    "build": "tsc -b && vite build",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist-server --emptyOutDir",
    "prerender": "node scripts/prerender.mjs",
    "build:static": "npm run build && npm run build:server && npm run prerender",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "vitest run && playwright test"
